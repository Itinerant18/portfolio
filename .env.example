# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_project_url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_anon_key

# Secret key for server-side sync (DO NOT prefix with NEXT_PUBLIC_)
# This key bypasses RLS and is required for background syncing if RLS is strict.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# GitHub Token for API sync
GITHUB_TOKEN=your_github_pat

# Optional hardening for /api/sync-project-architecture
ARCH_SYNC_TOKEN=your_long_random_sync_token

# OpenAI API Key (for Agent AI chat)
OPENAI_API_KEY=your_openai_api_key_here
